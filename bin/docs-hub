#!/usr/bin/env bash
# docs-hub — shared docs CLI. See README.md and the spec for details.
#
# Note: we deliberately avoid `set -e` per spec §11 ("no set -e aborts
# mid-output"). Each command function handles its own errors explicitly.

set -u
set -o pipefail

DH_VERSION="0.1.0"

# Resolve the directory containing this script, following symlinks one level.
dh_resolve_self() {
    local src="${BASH_SOURCE[0]}"
    while [ -L "$src" ]; do
        local target
        target="$(readlink -- "$src")"
        case "$target" in
            /*) src="$target" ;;
            *)  src="$(dirname -- "$src")/$target" ;;
        esac
    done
    cd -- "$(dirname -- "$src")" && pwd -P
}

DH_SCRIPT_DIR="$(dh_resolve_self)"
DH_LIB_DIR="$(dirname -- "$DH_SCRIPT_DIR")/lib"
DH_TEMPLATES_DIR="$(dirname -- "$DH_SCRIPT_DIR")/templates"
export DH_SCRIPT_DIR DH_LIB_DIR DH_TEMPLATES_DIR

# shellcheck source=../lib/util.sh
. "$DH_LIB_DIR/util.sh"

usage() {
    cat <<EOF
docs-hub — shared docs CLI (v$DH_VERSION)

Usage:
  docs-hub <command> [args]

Commands:
  init [<root>]                  Initialize a shared-docs root (default: ~/workplace/shared-docs)
  link <project> [--as <dir>]    Symlink a project's docs/ into the shared root
  unlink <project>               Remove the symlink and unregister a project
  new plan <slug>                Create plans/YYYY-MM-DD-<slug>.md from template
  ls [<type>]                    List docs (plans|architecture|runbooks|all). Default: plans
  status                         Health report for the shared root and all linked projects
  search <keyword>               grep across all docs (uses ripgrep when available)
  help [<command>]               Show help for a command
  version                        Print version

Run 'docs-hub <command> --help' for command-specific options.
EOF
}

cmd_help() {
    case "${1:-}" in
        init|link|unlink|new|ls|status|search)
            # shellcheck source=/dev/null
            . "$DH_LIB_DIR/cmd_${1}.sh"
            "cmd_${1}_help"
            ;;
        ""|help) usage ;;
        *) dh_err "unknown command: $1"; usage >&2; return 1 ;;
    esac
}

main() {
    local cmd="${1:-}"
    [ $# -gt 0 ] && shift || true

    case "$cmd" in
        ""|-h|--help|help)
            if [ "$cmd" = "help" ]; then
                cmd_help "$@"
            else
                usage
            fi
            ;;
        version|-v|--version)
            printf 'docs-hub %s\n' "$DH_VERSION"
            ;;
        init)
            . "$DH_LIB_DIR/cmd_init.sh"
            cmd_init "$@"
            ;;
        link)
            . "$DH_LIB_DIR/cmd_link.sh"
            cmd_link "$@"
            ;;
        unlink)
            . "$DH_LIB_DIR/cmd_unlink.sh"
            cmd_unlink "$@"
            ;;
        new)
            . "$DH_LIB_DIR/cmd_new.sh"
            cmd_new "$@"
            ;;
        ls)
            . "$DH_LIB_DIR/cmd_ls.sh"
            cmd_ls "$@"
            ;;
        status)
            . "$DH_LIB_DIR/cmd_status.sh"
            cmd_status "$@"
            ;;
        search)
            . "$DH_LIB_DIR/cmd_search.sh"
            cmd_search "$@"
            ;;
        *)
            dh_err "unknown command: $cmd"
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
