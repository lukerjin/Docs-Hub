#!/usr/bin/env bash
# inkwell — shared docs CLI. See README.md and the spec for details.
#
# Note: we deliberately avoid `set -e` per spec §11 ("no set -e aborts
# mid-output"). Each command function handles its own errors explicitly.

set -u
set -o pipefail

INK_VERSION="0.1.0"

# Resolve the directory containing this script, following symlinks one level.
ink_resolve_self() {
    local src="${BASH_SOURCE[0]}"
    while [ -L "$src" ]; do
        local target
        target="$(readlink -- "$src")"
        case "$target" in
            /*) src="$target" ;;
            *)  src="$(dirname -- "$src")/$target" ;;
        esac
    done
    cd -- "$(dirname -- "$src")" && pwd -P
}

INK_SCRIPT_DIR="$(ink_resolve_self)"
INK_LIB_DIR="$(dirname -- "$INK_SCRIPT_DIR")/lib"
INK_TEMPLATES_DIR="$(dirname -- "$INK_SCRIPT_DIR")/templates"
export INK_SCRIPT_DIR INK_LIB_DIR INK_TEMPLATES_DIR

# shellcheck source=../lib/util.sh
. "$INK_LIB_DIR/util.sh"

usage() {
    cat <<EOF
inkwell — shared docs CLI (v$INK_VERSION)

Usage:
  inkwell <command> [args]

Commands:
  init [<root>]                  Initialize a shared-docs root (default: ~/workplace/shared-docs)
  link <project> [--as <dir>]    Symlink a project's docs/ into the shared root
  unlink <project>               Remove the symlink and unregister a project
  new plan <slug>                Create plans/YYYY-MM-DD-<slug>.md from template
  ls [<type>]                    List docs (plans|architecture|runbooks|all). Default: plans
  status                         Health report for the shared root and all linked projects
  search <keyword>               grep across all docs (uses ripgrep when available)
  help [<command>]               Show help for a command
  version                        Print version

Run 'inkwell <command> --help' for command-specific options.
EOF
}

cmd_help() {
    case "${1:-}" in
        init|link|unlink|new|ls|status|search)
            # shellcheck source=/dev/null
            . "$INK_LIB_DIR/cmd_${1}.sh"
            "cmd_${1}_help"
            ;;
        ""|help) usage ;;
        *) ink_err "unknown command: $1"; usage >&2; return 1 ;;
    esac
}

main() {
    local cmd="${1:-}"
    [ $# -gt 0 ] && shift || true

    case "$cmd" in
        ""|-h|--help|help)
            if [ "$cmd" = "help" ]; then
                cmd_help "$@"
            else
                usage
            fi
            ;;
        version|-v|--version)
            printf 'inkwell %s\n' "$INK_VERSION"
            ;;
        init)
            . "$INK_LIB_DIR/cmd_init.sh"
            cmd_init "$@"
            ;;
        link)
            . "$INK_LIB_DIR/cmd_link.sh"
            cmd_link "$@"
            ;;
        unlink)
            . "$INK_LIB_DIR/cmd_unlink.sh"
            cmd_unlink "$@"
            ;;
        new)
            . "$INK_LIB_DIR/cmd_new.sh"
            cmd_new "$@"
            ;;
        ls)
            . "$INK_LIB_DIR/cmd_ls.sh"
            cmd_ls "$@"
            ;;
        status)
            . "$INK_LIB_DIR/cmd_status.sh"
            cmd_status "$@"
            ;;
        search)
            . "$INK_LIB_DIR/cmd_search.sh"
            cmd_search "$@"
            ;;
        *)
            ink_err "unknown command: $cmd"
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
